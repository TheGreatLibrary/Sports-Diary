<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SportsDiary" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="CircleDay">
        <item name="android:layout_width">34dp</item>
        <item name="android:layout_height">34dp</item>
        <item name="android:background">@drawable/bg_round_shape</item>
        <item name="android:textSize">16sp</item>
        <item name="android:gravity">center</item>
        <item name="android:backgroundTint">@color/gray_btn</item>
        <item name="android:textColor">@android:color/white</item>
    </style>


    <style name="DayTitle">
        <item name="android:textSize">18sp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>